{
  "app": {
    "name": "Image Reconstruction API",
    "version": "1.0.0",
    "description": "Image reconstruction service using PyTorch models",
    "docs_enabled": false
  },
  "backend": {
    "host": "0.0.0.0",
    "port": 8000,
    "reload": false,
    "model": {
      "path": "backend/model/ConvNext_REAL-ESRGAN.pth",
      "device": "auto"
    },
    "upload": {
      "max_size_mb": 1.5,
      "max_pixels": 40000000,
      "allowed_mime_types": [
        "image/png",
        "image/jpeg",
        "image/jpg",
        "image/webp"
      ],
      "allowed_extensions": [
        ".png",
        ".jpg",
        ".jpeg",
        ".webp"
      ]
    },
    "cors": {
      "allowed_origins": [
        "https://pixup.id",
        "https://www.pixup.id",
        "http://localhost:5173",
        "http://localhost:8000"
      ],
      "allow_credentials": false,
      "allow_methods": ["GET", "POST", "DELETE", "OPTIONS"],
      "allow_headers": ["*"]
    },
    "directories": {
      "data_dir": "backend/data",
      "uploads_dir": "backend/data/uploads",
      "outputs_dir": "backend/data/outputs",
      "models_dir": "backend/model"
    },
    "jobs": {
      "max_concurrent": 2,
      "busy_message": "Server is currently processing {max_concurrent} images. Please wait a moment and try again."
    },
    "cleanup": {
      "enabled": true,
      "interval_hours": 1,
      "max_age_hours": 1
    }
  },
  "frontend": {
    "port": 5173,
    "backend_url": "https://pixup.id",
    "auto_open_browser": true,
    "file_input": {
      "accept": "image/*"
    },
    "polling": {
      "interval_ms": 800,
      "retry_attempts": 3
    },
    "ui": {
      "title": "Image Reconstruction",
      "enable_model_selection": false,
      "labels": {
        "input": "Input Image",
        "output": "Output",
        "ok_button": "Submit",
        "cancel_button": "Cancel",
        "download_button": "Download Result"
      },
      "messages": {
        "uploading": "Uploading...",
        "cancelling": "Cancelling...",
        "file_too_large": "File too large (max {max_size}MB)",
        "file_type_not_allowed": "File type not allowed. Use: {allowed_types}",
        "polling_error": "Polling error: {error}",
        "create_job_failed": "Failed to create job"
      },
      "preview_enabled": true,
      "download_enabled": true,
      "show_progress_bar": true,
      "preview_alt_text": "Output preview"
    }
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  }
}
